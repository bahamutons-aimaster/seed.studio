# Salin file ini jadi .env (untuk lokal) atau set sebagai Environment Variables di Netlify Dashboard.
# Site settings > Environment variables > Add a variable

# Password untuk login ke /admin.html
ADMIN_PASSWORD=ganti-password-ini

# Secret untuk sign session cookie — bikin string random panjang, jangan dipakai ulang dari project lain
ADMIN_SESSION_SECRET=ganti-dengan-string-random-panjang-banget
